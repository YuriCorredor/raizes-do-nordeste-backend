{
  "name": "raizes-do-nordeste-backend",
  "version": "1.0.0",
  "description": "MVP back-end da rede Raizes do Nordeste",
  "main": "index.js",
  "scripts": {
    "dev": "node --no-warnings --watch src/servidor.js",
    "start": "node --no-warnings src/servidor.js",
    "migrate": "node --no-warnings scripts/migrar.js",
    "seed": "node --no-warnings scripts/seed.js",
    "reset-db": "node --no-warnings scripts/limpar-banco.js && npm run migrate && npm run seed",
    "test": "node --no-warnings scripts/testar-api.js"
  },
  "keywords": [
    "backend",
    "uninter",
    "api",
    "sqlite"
  ],
  "author": "Aluno",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "swagger-ui-express": "^5.0.1"
  }
}
