          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/unidades"
          }
        },
        {
          "name": "T03 - Cardapio unidade 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
