              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('resposta paginada', function () { pm.expect(pm.response.json()).to.have.property('dados'); });"
                ]
              }
