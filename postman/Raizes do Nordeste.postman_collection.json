    {
      "name": "Fluxo principal",
      "item": [
        {
          "name": "T04 - Criar pedido valido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test('pedido aguardando pagamento', function () { pm.expect(json.status).to.eql('AGUARDANDO_PAGAMENTO'); });",
                  "pm.test('tem canal TOTEM', function () { pm.expect(json.canalPedido).to.eql('TOTEM'); });",
                  "pm.collectionVariables.set('pedidoId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clienteToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"canalPedido\": \"TOTEM\",\n  \"formaPagamento\": \"MOCK\",\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 2 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/pedidos"
          }
        },
        {
          "name": "T05 - Aprovar pagamento mock",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test('pagamento aprovado', function () { pm.expect(json.status).to.eql('APROVADO'); });",
                  "pm.test('pedido em preparo', function () { pm.expect(json.pedidoStatus).to.eql('EM_PREPARO'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clienteToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pedidoId\": {{pedidoId}},\n  \"aprovado\": true\n}"
            },
            "url": "{{baseUrl}}/pagamentos/mock"
          }
        },
        {
          "name": "T06 - Atualizar status para PRONTO",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('pedido ficou pronto', function () { pm.expect(pm.response.json().status).to.eql('PRONTO'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{cozinhaToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PRONTO\"\n}"
            },
            "url": "{{baseUrl}}/pedidos/{{pedidoId}}/status"
          }
        },
        {
          "name": "T07 - Listar pedidos por canal",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('resposta paginada', function () { pm.expect(pm.response.json()).to.have.property('dados'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": "{{baseUrl}}/pedidos?canalPedido=TOTEM"
          }
        },
        {
          "name": "T08 - Consultar fidelidade",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('tem pontos', function () { pm.expect(pm.response.json()).to.have.property('pontos'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
            "url": "{{baseUrl}}/fidelidade/saldo"
          }
        }
